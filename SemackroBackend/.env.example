# Example environment variables for SemackroBackend
# Copy to .env and fill with real values (DO NOT commit .env)
DB_HOST=replace_me
DB_PORT=3306
DB_USER=replace_me
DB_PASSWORD=replace_me
DB_NAME=replace_me

# Development overrides (only used when NODE_ENV != production)
DB_HOST_OVERRIDE=
DB_PORT_OVERRIDE=

# Frontend
FRONTEND_URL=http://localhost:5050

# Other services (Cloudflare R2)
R2_ACCOUNT_ID=replace_me
R2_ACCESS_KEY_ID=replace_me   # Or use R2_ACCESS_KEY (for backwards compatibility)
R2_SECRET_ACCESS_KEY=replace_me # Or use R2_SECRET_KEY (for backwards compatibility)
R2_BUCKET_NAME=replace_me
R2_PUBLIC_URL=replace_me
OAUTH_CLIENT_ID=replace_me
OAUTH_CLIENT_SECRET=replace_me

# NODE_ENV=development | production
NODE_ENV=development
